              "pm.test(\"status is 200\", () => pm.response.to.have.status(200));",
              "pm.test(\"documents the stream endpoint\", () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.paths).to.have.property(\"/api/v1/agent/stream\");",
              "});"
            ]
          }
        }
      ]
    }
