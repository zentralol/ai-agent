APP_ENV=development
HOST=0.0.0.0
PORT=8010

# LLM provider. DeepSeek can use OpenAI-compatible base URLs.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.deepseek.com/v1

# Internal service-to-service auth. The Express gateway must send this exact
# value as the X-Internal-Service-Token header. Must match the backend's
# AGENT_INTERNAL_TOKEN. Generate: openssl rand -hex 32.
# If unset, inbound auth is skipped (development only).
AGENT_INTERNAL_TOKEN=replace-me

# Supabase stays server-side. It is used for controlled preference lookup and
# later for agent-owned run/trace tables.
SUPABASE_URL=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_USER_PREFERENCES_TABLE=onboarding_preferences
SUPABASE_TIMEOUT_SECONDS=3

# Conversation persistence: how many most-recent messages to load as model
# context per turn. (Table names are fixed to match the Supabase migrations.)
CONVERSATION_HISTORY_LIMIT=20

# Google Maps Platform, server-side. Enable "Places API (New)" for this key.
# Used by the nearby-places tool. If unset, that tool degrades with a warning.
GOOGLE_MAPS_API_KEY=replace-me
