APP_ENV=development
HOST=0.0.0.0
PORT=8010

# Internal gateway token used by Express -> zentra-agent calls.
INTERNAL_GATEWAY_TOKEN=replace-me

# Existing Zentra Express backend base URL.
ZENTRA_BACKEND_BASE_URL=http://localhost:3000/api/v1

# LLM provider. DeepSeek can use OpenAI-compatible base URLs.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.deepseek.com/v1

# Supabase is only for agent-owned tables, not client-side access.
SUPABASE_URL=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

